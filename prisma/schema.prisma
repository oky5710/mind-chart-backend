generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// 사용자
// ──────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  googleId  String?  @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events            Event[]
  hrvAnalyses       HrvAnalysis[]
  medicationLogs    MedicationLog[]
  medicationChanges MedicationChange[]
  wearableData      WearableData[]
  wearableSamples   WearableSample[]
  exercises         Exercise[]
  coffeeLogs        CoffeeLog[]
  moodLogs          MoodLog[]
}

// ──────────────────────────────────────────
// 이벤트 (캘린더에 기록하는 정신건강 관련 사건)
// ──────────────────────────────────────────
model Event {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime   @db.Date
  type        EventType
  title       String
  description String?
  sentiment   Sentiment
  intensity   Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum EventType {
  FRIEND_MEETING
  CONCERT
  RELATIONSHIP_STRESS
  CONFLICT
  EXERCISE
  HOBBY
  OTHER
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

// ──────────────────────────────────────────
// HRV(심박변이도) 검사 결과
// ──────────────────────────────────────────
model HrvAnalysis {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examinedAt DateTime
  hospital   String?
  memo       String?

  // Time Domain Analysis
  mhr   Float
  sdnn  Float
  rmssd Float
  psi   Float

  // Frequency Domain Analysis
  tp  Float
  vlf Float
  lf  Float
  hf  Float

  lfNorm      Float
  hfNorm      Float
  lfHfRatio   Float
  ectopicBeat Float

  // Other
  srd    Float
  result String

  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────
// 약 정보 (마스터 테이블)
// ──────────────────────────────────────────
model Medication {
  id         String    @id @default(cuid())
  itemSeq    String?   @unique
  name       String
  entpName   String?
  itemImage  String?
  drugShape  String?
  colorClass String?
  chart      String?
  timings    String[]
  deletedAt  DateTime?

  logs    MedicationLog[]
  changes MedicationChange[]
}

// ──────────────────────────────────────────
// 약 복용 기록 (날짜별 복용 여부)
// ──────────────────────────────────────────
model MedicationLog {
  id           String     @id @default(cuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id])
  date         DateTime   @db.Date
  dosage       Float
  taken        Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([userId, medicationId, date])
}

// ──────────────────────────────────────────
// 약 변동 기록 (처방 변경 이력)
// ──────────────────────────────────────────
model MedicationChange {
  id             String     @id @default(cuid())
  userId         String?
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicationId   String
  medication     Medication @relation(fields: [medicationId], references: [id])
  date           DateTime   @db.Date
  changeType     ChangeType
  previousDosage Float?
  newDosage      Float?
  reason         String?
  createdAt      DateTime   @default(now())
}

enum ChangeType {
  STARTED
  STOPPED
  DOSAGE_INCREASED
  DOSAGE_DECREASED
}

// ──────────────────────────────────────────
// 운동 기록
// ──────────────────────────────────────────
model Exercise {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime  @db.Date
  type            String
  durationMinutes Int
  intensity       Int? // 단축어 자동화는 강도를 알 수 없어 비워둘 수 있음
  startedAt       DateTime? // 운동 시작 시각
  endedAt         DateTime? // 운동 종료 시각
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ──────────────────────────────────────────
// 커피 섭취 기록
// ──────────────────────────────────────────
model CoffeeLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String?
  shots     Int?
  memo      String?
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────
// 기분 기록 (5점 척도)
// ──────────────────────────────────────────
model MoodLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  score     Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// ──────────────────────────────────────────
// 웨어러블 데이터 (Apple Health 연동, 일별 요약)
// ──────────────────────────────────────────
model WearableData {
  id                   String   @id @default(cuid())
  userId               String?
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                 DateTime @db.Date
  sleepDuration        Float?   // 수면 시간 (시간 단위)
  sleepStart           DateTime? // 수면 시작 시각
  sleepEnd             DateTime? // 수면 종료(기상) 시각
  sleepQuality         Int?     // 수면 품질 1~5
  heartRate            Float?   // 평균 심박수 (BPM)
  heartRateVariability Float?   // HRV SDNN (ms, Apple Watch)
  createdAt            DateTime @default(now())

  @@unique([userId, date])
}

// ──────────────────────────────────────────
// 웨어러블 원본 샘플 (타임스탬프별 다건 기록 — 애플워치는 HRV를
// 하루에 여러 번, 대략 2시간 간격으로 측정함)
// ──────────────────────────────────────────
model WearableSample {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "heartRate" | "heartRateVariability"
  timestamp DateTime
  value     Float
  createdAt DateTime @default(now())

  @@unique([userId, type, timestamp])
  @@index([type, timestamp])
}
